<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:startDestination="@id/loginFragment">


    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.dp_app.fragments.LoginFragment"
        android:label="Login">
        
        <action
            android:id="@+id/action_loginFragment_to_introFragment"
            app:destination="@id/introFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>


    <fragment
        android:id="@+id/introFragment"
        android:name="com.example.dp_app.fragments.IntroFragment"
        android:label="Intro">

        <action
            android:id="@+id/action_introFragment_to_behametricsFragment"
            app:destination="@id/behametricsFragment" />
        <action
            android:id="@+id/action_introFragment_to_behametricsTouchFragment"
            app:destination="@id/behametricsTouchFragment" />
        <action
            android:id="@+id/action_introFragment_to_sensorFragment"
            app:destination="@id/sensorFragment" />
        <action
            android:id="@+id/action_introFragment_to_cropFragment"
            app:destination="@id/cropFragment" />
        <action
            android:id="@+id/action_introFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/introFragment"
            app:popUpToInclusive="true" />
    </fragment>


    <fragment
        android:id="@+id/behametricsFragment"
        android:name="com.example.dp_app.fragments.BehametricsFragment"
        android:label="BehametricsFragment">
        
        <action
            android:id="@+id/action_behametricsFragment_to_introFragment"
            app:destination="@id/introFragment"
            app:popUpTo="@id/introFragment"
            app:popUpToInclusive="true" />
    </fragment>


    <fragment
        android:id="@+id/behametricsTouchFragment"
        android:name="com.example.dp_app.fragments.BehametricsTouchFragment"
        android:label="BehametricsTouchFragment">
        
        <action
            android:id="@+id/action_behametricsTouchFragment_to_introFragment"
            app:destination="@id/introFragment"
            app:popUpTo="@id/introFragment"
            app:popUpToInclusive="true" />
    </fragment>


    <fragment
        android:id="@+id/sensorFragment"
        android:name="com.example.dp_app.fragments.SensorFragment"
        android:label="SensorFragment">
        
        <action
            android:id="@+id/action_sensorFragment_to_introFragment"
            app:destination="@id/introFragment"
            app:popUpTo="@id/introFragment"
            app:popUpToInclusive="true" />
    </fragment>


    <fragment
        android:id="@+id/cropFragment"
        android:name="com.example.dp_app.fragments.CropFragment"
        android:label="CropFragment">
        
        <action
            android:id="@+id/action_cropFragment_to_introFragment"
            app:destination="@id/introFragment"
            app:popUpTo="@id/introFragment"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>
