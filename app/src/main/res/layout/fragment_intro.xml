<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp"
            android:layout_marginTop="16dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="16dp"
                android:contentDescription="Logo"
                android:src="@drawable/bb" />

            <TextView
                android:id="@+id/intro_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Výber aktivity"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/user_id_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Prihlásený: "
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

        </LinearLayout>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sensors"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Gestá v priestore"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="@color/accent"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_sensors"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_touch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Dotyková galéria"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="@color/accent_light"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:icon="@drawable/touch_ic"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logging"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Chôdza"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="@color/accent_light"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_settings"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/white" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_zoom"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="32dp"
            android:text="Dotykový zoom"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="@color/accent_light"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_zoom"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/white" />


        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginBottom="16dp" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Odhlásiť sa"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="@color/danger_light"
            android:backgroundTint="@color/bg_surface"
            app:rippleColor="#44EF4444" />

    </LinearLayout>

</ScrollView>
