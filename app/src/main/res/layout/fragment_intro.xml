<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="32dp"
            android:layout_marginTop="16dp">

            <ImageView
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginBottom="16dp"
                android:contentDescription="Logo"
                android:src="@drawable/bb" />

            <TextView
                android:id="@+id/intro_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Výber senzora"
                android:textColor="#2D3748"
                android:textSize="20sp"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/user_id_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Prihlásený: "
                android:textColor="#7C8DB0"
                android:textSize="13sp" />

        </LinearLayout>


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sensors"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Behametrics senzory"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="#7C8DB0"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_sensors"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_touch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Dotyková galéria"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="#9AA5B8"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:icon="@drawable/touch_ic"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logging"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="12dp"
            android:text="Chôdza"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="#A8B5C8"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_settings"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="#FFFFFF" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_zoom"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginBottom="32dp"
            android:text="Dotykový zoom"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="#B8C4D6"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            app:icon="@drawable/ic_zoom"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="#FFFFFF" />


        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E2E8F0"
            android:layout_marginBottom="16dp" />


        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_logout"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Odhlásiť sa"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="#D73232"
            android:backgroundTint="#E9E9E9"
            app:rippleColor="#FFCDD2" />

    </LinearLayout>

</ScrollView>
