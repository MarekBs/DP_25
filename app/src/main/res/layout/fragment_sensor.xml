<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/title_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chôdza"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/status_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pripravený na záznam"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/bg_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pokus"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <TextView
                    android:id="@+id/counter_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 / 15"
                    android:textSize="48sp"
                    android:textColor="@color/accent_soft"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Trvanie: ~16 sekúnd – zastaví sa automaticky\nUmiestnenie: zariadenie vložte do vrecka\nPohyb: choďte normálnym tempom po rovnom povrchu"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingMultiplier="1.4"
            android:layout_marginBottom="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/start_button"
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:text="Spustiť pokus"
            android:textAllCaps="false"
            android:textSize="15sp"
            app:backgroundTint="@color/accent"
            app:cornerRadius="12dp"
            app:elevation="0dp"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/back_button"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Späť na výber"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:textColor="@color/accent_light"
            android:visibility="gone" />

    </LinearLayout>

    </ScrollView>

    <FrameLayout
        android:id="@+id/upload_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC1F2937"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center">

            <ProgressBar
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:indeterminateTint="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ukladanie záznamu..."
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:layout_marginTop="16dp" />

        </LinearLayout>

    </FrameLayout>

    <FrameLayout
        android:id="@+id/success_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC1F2937"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="32dp">

            <TextView
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:text="✓"
                android:textColor="#FFFFFF"
                android:textSize="48sp"
                android:gravity="center"
                android:background="@drawable/check_circle_bg" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logovanie úspešné!"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Všetky pokusy boli úspešne uložené."
                android:textColor="#B0BEC5"
                android:textSize="14sp"
                android:layout_marginTop="8dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/success_menu_button"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:text="Hlavné menu"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:layout_marginTop="32dp"
                app:backgroundTint="@color/accent"
                app:cornerRadius="12dp"
                app:elevation="0dp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>
